{
  "manifest_version": 3,
  "name": "AK Streamers",
  "version": "1.0",
  "description": "Kick multi-channel monitor with smart automation and dashboard.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "tabs",
    "notifications",
    "scripting",
    "downloads" 
  ],
  "host_permissions": [
    "https://kick.com/*",
    "https://*.supabase.co/*",
    "https://*.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://kick.com/*"],
      "js": ["config.js", "utils.js", "stream_uptime.js", "kick_automation.js"],
      "run_at": "document_end"
    }
  ]
}
